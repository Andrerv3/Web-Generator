---
import { business } from '../../config/business';
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Card from '../ui/Card.astro';

const { services } = business;
---

<Section id="servicios" background="light">
  <Container size="xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-primary mb-12">Nuestros Servicios</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map((service) => (
        <Card class="p-8 flex flex-col items-center text-center">
          <h3 class="text-2xl font-bold text-primary mb-4">{service.name}</h3>
          <p class="text-neutral-dark mb-6 flex-1">{service.description}</p>
          <span class="text-xl font-bold text-secondary">{service.price}</span>
        </Card>
      ))}
    </div>
  </Container>
</Section>
