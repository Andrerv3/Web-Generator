---
import { business } from '../../config/business';
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';

const { about } = business;
---

<Section id="about" background="white" class="py-24">
  <Container size="xl">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="bg-neutral-light rounded-3xl h-[400px] flex items-center justify-center border border-neutral-light/20 shadow-xl order-2 md:order-1">
        <span class="text-neutral-dark/40 font-medium italic">Imagen del Negocio</span>
      </div>
      <div class="order-1 md:order-2">
        <h2 class="text-3xl md:text-5xl font-bold text-primary mb-8 leading-tight">{about.title}</h2>
        <p class="text-lg text-neutral-dark mb-6 leading-relaxed">{about.description1}</p>
        {about.description2 && <p class="text-lg text-neutral-dark leading-relaxed">{about.description2}</p>}
      </div>
    </div>
  </Container>
</Section>
