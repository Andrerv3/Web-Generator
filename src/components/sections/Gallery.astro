---
import { business } from '../../config/business';
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Card from '../ui/Card.astro';

const { gallery } = business;
---

<Section id="galeria" background="white">
  <Container size="xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-primary mb-12">Nuestros Trabajos</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {gallery.map((image) => (
        <Card class="aspect-square">
          <img src={image} alt="Imagen de trabajo realizado" class="w-full h-full object-cover" />
        </Card>
      ))}
    </div>
  </Container>
</Section>
