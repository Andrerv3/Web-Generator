---
import { business } from '../../config/business';
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';

const { faq } = business;
---

<Section id="faq" background="white">
  <Container size="md">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-primary mb-12">Preguntas Frecuentes</h2>
    <div class="space-y-4">
      {faq.map((item) => (
        <details class="group bg-neutral-light rounded-xl overflow-hidden">
          <summary class="p-6 font-bold text-primary cursor-pointer flex justify-between items-center">
            {item.question}
            <span class="group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="p-6 pt-0 text-neutral-dark">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </Container>
</Section>
