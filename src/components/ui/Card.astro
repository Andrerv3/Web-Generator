---
interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className, hover = true } = Astro.props;
---

<div class:list={[
  "bg-white border border-neutral-light/10 rounded-xl shadow-sm overflow-hidden",
  hover && "hover:shadow-md hover:-translate-y-0.5 transition-all duration-300",
  className
]}>
  <slot />
</div>
